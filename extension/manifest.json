{
  "manifest_version": 3,
  "minimum_chrome_version": "116",
  "name": "ModCrew",
  "version": "1.1.2",
  "description": "Mod the web. Together. AI-powered website modification via Claude Code.",
  "key": "",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "alarms",
    "sidePanel",
    "unlimitedStorage",
    "offscreen"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "sw.js",
    "type": "module"
  },
  "action": {
    "default_title": "ModCrew",
    "default_popup": "popup/panel.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup/panel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/auto-apply.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://modcrew.dev/*",
        "https://www.modcrew.dev/*"
      ],
      "js": [
        "content/token-sync.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "sandbox": {
    "pages": [
      "sandbox.html"
    ]
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "128": "icons/icon128.png"
  }
}
